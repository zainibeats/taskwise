# ---------------------------------------------------------------
# TaskWise — test environment template
# Copy this file to .env.test.local and fill in your values.
# .env.test.local is gitignored and will not be committed.
# ---------------------------------------------------------------

# --- AI provider ---
# lm_studio  : local, no API key needed (recommended for testing)
# ollama     : local, no API key needed
# google_ai  : cloud, requires GOOGLE_AI_API_KEY
# openai     : cloud, requires OPENAI_API_KEY
# anthropic  : cloud, requires ANTHROPIC_API_KEY
AI_PROVIDER=lm_studio

# --- LM Studio ---
# Linux  : localhost resolves to the host via host networking
# Mac/Win: change to http://host.docker.internal:1234/v1
LM_STUDIO_BASE_URL=http://localhost:1234/v1

# --- Ollama (alternative local option) ---
# Linux  : localhost resolves to the host via host networking
# Mac/Win: change to http://host.docker.internal:11434/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3.2

# --- Cloud providers (only needed if AI_PROVIDER is set to one of these) ---
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# --- Optional prompt suffix applied to all AI flows ---
AI_SYSTEM_PROMPT_APPEND=

# --- App ---
NODE_ENV=production
PORT=9002
DB_SERVER_PORT=3100
NEXT_PUBLIC_API_URL=http://localhost:3100
